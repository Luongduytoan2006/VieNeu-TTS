# ── backend-vps (CPU / logic tier) ───────────────────────────────────────────
# Copy to backend-vps/.env and fill in. This file is a template (safe to commit).

# Public API server
HOST=0.0.0.0
PORT=7862

# GPU model-server this BE forwards synthesis to. In split deploy this is the
# tunnel URL of the GPU box, e.g. https://vienue-tts.luongduytoan.io.vn
MODEL_SERVER_URL=http://127.0.0.1:9000
# Must match backend-model's MODEL_API_KEY.
MODEL_API_KEY=change-me-secret

# Database (durable jobs). Default = SQLite (zero-infra, runs with just uv).
# For Postgres: postgresql+psycopg://vieneu:vieneu@127.0.0.1:5432/vieneu
# VIENEU_DATABASE_URL=sqlite:///./data/vieneu.db

# Behind nginx/Cloudflare TLS termination → build https URLs
VIENEU_FORCE_HTTPS=0

# Synthesis defaults forwarded to the model-server
VIENEU_MAX_CHARS=256

PYTHONUNBUFFERED=1
