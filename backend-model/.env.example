# ── backend-model (GPU / AI tier) ────────────────────────────────────────────
# Copy to backend-model/.env and fill in. This file is a template (safe to commit).

# HTTP server
HOST=0.0.0.0
PORT=9000

# Shared bearer key between the model-server and backend-vps (must match both sides)
MODEL_API_KEY=change-me-secret

# Model
VIENEU_BACKBONE_REPO=pnnbao-ump/VieNeu-TTS-v3-Turbo
MODEL_EAGER_LOAD=1
VIENEU_MAX_NEW_FRAMES=300

# ── Storage: Cloudflare R2 (S3-compatible) ───────────────────────────────────
STORAGE_BACKEND=r2
R2_URL=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY=<r2-access-key-id>
R2_SECRET_KEY=<r2-secret-access-key>
R2_BUCKET=vieneu-tts
# Presigned GET URL lifetime (seconds). BE downloads audio via this URL, no creds.
R2_PRESIGN_TTL=86400
# Optional: an R2 public bucket / custom domain → permanent public URLs instead of presigned.
# R2_PUBLIC_BASE=https://cdn.example.com

# Local-storage fallback (only if STORAGE_BACKEND=local)
# MODEL_SERVER_PUBLIC_URL=http://localhost:9000
# STORAGE_LOCAL_DIR=/workspace/.ask/storage

PYTHONUNBUFFERED=1
