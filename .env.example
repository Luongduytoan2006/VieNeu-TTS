# ── VieNeu-TTS — .env (Ở REPO ROOT, nguồn cấu hình chính) ─────────────────────
# Copy sang .env và điền. File này là template (an toàn để commit).
# server/src/config.py đọc .env ở root này TRƯỚC (ưu tiên), server/.env chỉ fallback.

# ── HTTP server (public API) ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=7862
# Sau nginx/Cloudflare TLS → build https URL
VIENEU_FORCE_HTTPS=0
# Base URL công khai của server này (để build URL /files/... khi storage=local)
VIENEU_PUBLIC_BASE=http://localhost:7862
# CORS — giao diện giờ CÙNG origin (/), không cần. Chỉ dùng nếu gọi API từ origin khác.
VIENEU_CORS_ORIGINS=*

# ── Giao diện UI (phục vụ tại "/" NGAY TRÊN app API, cùng cổng PORT=7862) ─────
# main.py phục vụ ui/index.html tại "/". Tắt giao diện: =0.
VIENEU_SERVE_UI=1
# URL API mà giao diện gọi tới (client-side). ĐỂ RỖNG = tương đối, cùng origin
# (chạy sau mọi proxy/domain). Chỉ đặt khi API nằm ở host/domain khác.
# VIENEU_API_BASE=
# Thư mục giao diện (mặc định repo-root/ui).
# VIENEU_UI_DIR=

# ── Model (CPU / in-process) ─────────────────────────────────────────────────
VIENEU_BACKBONE_REPO=pnnbao-ump/VieNeu-TTS-v3-Turbo
# auto → CUDA nếu có, else ONNX/CPU. Server VPS mặc định CPU.
VIENEU_DEVICE=auto
MODEL_EAGER_LOAD=1
VIENEU_MAX_CHARS=256
VIENEU_MAX_NEW_FRAMES=300

# ── Ngưỡng chọn mode ─────────────────────────────────────────────────────────
# GPU chỉ được phép khi context ≥ ngần này TỪ (tách theo khoảng trắng).
VIENEU_GPU_MIN_WORDS=1000

# ── Database (PostgreSQL — giọng custom của user + jobs) ─────────────────────
# Credential Postgres — docker compose dựng container 'db' từ 3 biến này.
POSTGRES_USER=vieneu
POSTGRES_PASSWORD=vieneu
POSTGRES_DB=vieneu
# Chuỗi app dùng để nối DB:
#   • Chạy BẰNG DOCKER (compose): host = tên service 'db' → giữ @db:5432.
#   • Chạy TAY ngoài Docker:      đổi 'db'→'localhost' và '5432'→'7432'.
DATABASE_URL=postgresql://vieneu:vieneu@db:5432/vieneu

# ── Storage audio kết quả ────────────────────────────────────────────────────
# local → lưu đĩa, phục vụ qua /files/{key}. r2 → Cloudflare R2 (presigned URL).
STORAGE_BACKEND=local
# STORAGE_LOCAL_DIR=  (mặc định server/data)

# ── Cloudflare R2 (khi STORAGE_BACKEND=r2) ───────────────────────────────────
# config.py chấp nhận cả tên hoa (R2_URL) lẫn thường (R2_url).
R2_url=https://<accountid>.r2.cloudflarestorage.com
R2_access_key=<r2-access-key-id>
R2_secret_key=<r2-secret-access-key>
R2_BUCKET=vieneu-tts
R2_PRESIGN_TTL=86400
# R2_PUBLIC_BASE=https://cdn.example.com

# ── Vast.ai (GPU on-demand) — server/src/services/gpu_vastai.py ───────────────
# Key tạo với 2FA OFF + quyền Instances R/W + Misc + Billing-R + User-R.
VAST_AI_API_KEY=<vast-ai-key>
VAST_GPU_NAME=RTX 3060          # tên GPU (DẤU CÁCH, không phải RTX_3060)
VAST_MAX_DPH=0.10              # giá tối đa $/giờ
VAST_CUDA_MIN=12.8            # CUDA tối thiểu (yêu cầu tác giả)
VAST_DISK_GB=40
VAST_MIN_INET_DOWN=300        # Mbps (tải model HF nhanh)
VAST_ONLY_VERIFIED=1         # chỉ máy verified (chạy data khách)
VAST_IMAGE=pytorch/pytorch:2.8.0-cuda12.8-cudnn9-devel
# SSH private key (đã add public key lên Vast account) để SCP code + lấy WAV về.
VAST_SSH_KEY=~/.ssh/Desktoplenovo
VAST_BOOT_TIMEOUT=600        # chờ máy running (s)
VAST_JOB_TIMEOUT=1200        # chờ synth xong (s)
VAST_POLL_SEC=30             # nhịp poll (TIỀN THẬT — đừng poll quá dày)

PYTHONUNBUFFERED=1
